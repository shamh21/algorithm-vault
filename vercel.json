{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "env": {
    "WALLET_REAL_CUSTODY_ENABLED": "true",
    "WALLET_EVM_NETWORKS_JSON": "{\"ETHEREUM\":{\"rpc_url\":\"https://ethereum.publicnode.com\",\"chain_id\":1}}",
    "WALLET_EVM_TOKEN_CONTRACTS_JSON": "{\"ETHEREUM\":{\"USDC\":\"0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48\",\"USDC_DECIMALS\":6,\"USDT\":\"0xdAC17F958D2ee523a2206206994597C13D831ec7\",\"USDT_DECIMALS\":6}}",
    "WALLET_BTC_INDEXER_URL": "https://mempool.space/api",
    "WALLET_SOLANA_RPC_URL": "https://api.mainnet-beta.solana.com",
    "WALLET_XRP_RPC_URL": "https://s1.ripple.com:51234/",
    "WALLET_REQUIRED_CONFIRMATIONS_JSON": "{\"ethereum\":12,\"bitcoin\":2,\"solana\":32,\"xrpledger\":1}"
  },
  "builds": [
    {"src": "static/**/*", "use": "@vercel/static"},
    {
      "src": "server.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": "{.coverage,.DS_Store,**/.DS_Store,.env,.env*,.github/**,.local-certs/**,.pre-commit-config.yaml,.vercelignore,CODEX_APP_SUMMARY.md,EFFICIENCY_WEAK_POINTS.md,pyproject.toml,pytest.ini,render.yaml,requirements-dev.txt,requirements-exchanges.txt,requirements-full.txt,requirements-ml.txt,requirements-torch.txt,requirements-wallets.txt,run.py,wsgi.py,uv.lock,instance/**,logs/**,tests/**,deploy/**,admin-pwa/**,docs/**,public/**,static/**,.venv/**,.venv.*/**,venv/**,env/**,.vercel/**,.pytest_cache/**,.mypy_cache/**,.ruff_cache/**,htmlcov/**,__pycache__/**,**/__pycache__/**,*.db,*.sqlite,*.sqlite3,*.db-*,*.sqlite-*,*.sqlite3-*,*.backup*}"
      }
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"},
        {"key": "Service-Worker-Allowed", "value": "/"}
      ]
    },
    {
      "source": "/static/js/sw.js",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"},
        {"key": "Service-Worker-Allowed", "value": "/"}
      ]
    },
    {"source": "/manifest.json", "headers": [{"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"}]},
    {"source": "/manifest.webmanifest", "headers": [{"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"}]},
    {"source": "/static/css/(.*)", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]},
    {"source": "/static/js/app-shell.js", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]},
    {"source": "/static/js/vendor/(.*)", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]},
    {"source": "/static/(.*)", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]},
    {"source": "/resources", "headers": [{"key": "Cache-Control", "value": "public, max-age=300, must-revalidate"}]},
    {
      "source": "/resources/(.*)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=300, must-revalidate"},
        {"key": "X-Content-Type-Options", "value": "nosniff"}
      ]
    },
    {
      "source": "/resources/flask.pdf",
      "headers": [
        {"key": "Content-Type", "value": "application/pdf"},
        {"key": "Content-Disposition", "value": "inline; filename=complete-a-z-flask-guide.pdf"}
      ]
    }
  ],
  "rewrites": [
    {"source": "/sw.js", "destination": "/static/js/sw.js"},
    {"source": "/static/(.*)", "destination": "/static/$1"},
    {"source": "/icons/(.*)", "destination": "/static/icons/$1"},
    {"source": "/manifest.json", "destination": "/static/manifest.json"},
    {"source": "/manifest.webmanifest", "destination": "/static/manifest.webmanifest"},
    {"source": "/resources", "destination": "/static/resources/index.html"},
    {"source": "/resources/", "destination": "/static/resources/index.html"},
    {"source": "/resources/axios", "destination": "/static/resources/axios.html"},
    {"source": "/resources/axios/", "destination": "/static/resources/axios.html"},
    {"source": "/resources/flask", "destination": "/static/resources/complete-a-z-flask-guide.pdf"},
    {"source": "/resources/flask/", "destination": "/static/resources/complete-a-z-flask-guide.pdf"},
    {"source": "/resources/flask.pdf", "destination": "/static/resources/complete-a-z-flask-guide.pdf"},
    {"source": "/(.*)", "destination": "/server.py"}
  ]
}
