# Local developer environment template.
# Copy to .env and replace placeholders. Never commit .env.

# Flask/runtime
FLASK_APP=wsgi:app
FLASK_DEBUG=1
FLASK_SECRET_KEY=replace-with-a-local-32-plus-character-secret
ADMIN_USERNAME=admin
# Optional. Leave blank to register the first local user through the app.
ADMIN_PASSWORD=
# Optional. Leave blank unless you want invite-only local registration.
SIGNUP_INVITE_CODE=
# Required for stable 2FA/connection encryption. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=replace-with-a-generated-fernet-key
DATABASE_URL=sqlite:///hyperliquid_dashboard.db
# VPS/Postgres example:
# DATABASE_URL=postgresql+psycopg://tradingbot:<password>@127.0.0.1:5432/tradingbot
DEPLOYMENT_TARGET=local
PUBLIC_APP_ORIGIN=
PUBLIC_API_ORIGIN=
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
WORKER_MODE=local
ENABLE_IN_PROCESS_WORKERS=true
WORKER_PROCESS_CONFIGURED=false
WORKER_LEASE_TTL_SECONDS=120
WORKER_POLL_SECONDS=15

# Optional local HTTPS desktop diagnostics. Do not use these self-signed
# certificates for iPhone PWA install testing; use a stable public HTTPS host.
# Prefer ignored .env.local-https for machine-specific paths generated by
# scripts/create_local_https_cert.sh.
# LOCAL_HTTPS_CERT=.local-certs/algorithm-vault-local.crt
# LOCAL_HTTPS_KEY=.local-certs/algorithm-vault-local.key

# Runtime posture. Keep paper by default; live orders require explicit opt-in, verified connections, and risk gates.
ENABLE_LIVE_TRADING=false
APP_MODE=paper
EXPLICIT_LIVE_CONFIRMED=false
SECONDARY_CONFIRMATION=false
WALLET_CUSTODY_MODE=local_dev
WALLET_WITHDRAWALS_ENABLED=false
WALLET_EMERGENCY_STOP=false
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_WALLET=0
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_ASSET_JSON={}
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_DESTINATION=0
WALLET_DAILY_GLOBAL_WITHDRAWAL_LIMIT=0

# Audit efficiency. Compact/throttle repeated no-trade diagnostics and prune old noisy rows with the CLI.
NO_TRADE_AUDIT_COMPACT_ENABLED=true
NO_TRADE_AUDIT_THROTTLE_SECONDS=300
NO_TRADE_AUDIT_RETENTION_HOURS=24
TRANSIENT_AUDIT_RETENTION_HOURS=72

# Dynamic intraday optimizer
DYNAMIC_UNIVERSE_ENABLED=true
DYNAMIC_INTRADAY_TIMEFRAMES=1m,5m,15m
DYNAMIC_INTRADAY_MIN_EDGE_BPS=6
DYNAMIC_INTRADAY_MIN_LIQUIDITY_USD=50000
DYNAMIC_INTRADAY_MAX_SPREAD_BPS=12
DYNAMIC_INTRADAY_REQUIRE_SHADOW_VALIDATION=true
DYNAMIC_INTRADAY_LIVE_ELIGIBLE=false

# Explicit high-upside profile. Defaults stay capped unless every opt-in gate is set.
