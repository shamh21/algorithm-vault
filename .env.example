# Flask/runtime
FLASK_SECRET_KEY=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
TOTP_ENCRYPTION_KEY=<required Fernet key>
DATABASE_URL=sqlite:///hyperliquid_dashboard.db

# Live-only runtime posture. Live orders still require verified connections and risk gates.
ENABLE_LIVE_TRADING=true
APP_MODE=live
EXPLICIT_LIVE_CONFIRMED=false
SECONDARY_CONFIRMATION=false

# Dynamic intraday optimizer
DYNAMIC_UNIVERSE_ENABLED=true
DYNAMIC_INTRADAY_TIMEFRAMES=1m,5m,15m
DYNAMIC_INTRADAY_MIN_EDGE_BPS=6
DYNAMIC_INTRADAY_MIN_LIQUIDITY_USD=50000
DYNAMIC_INTRADAY_MAX_SPREAD_BPS=12
DYNAMIC_INTRADAY_REQUIRE_SHADOW_VALIDATION=true
DYNAMIC_INTRADAY_LIVE_ELIGIBLE=false

# Explicit high-upside profile. Defaults stay capped unless every opt-in gate is set.
HIGH_UPSIDE_PROFILE_ENABLED=false
HIGH_UPSIDE_LIVE_ELIGIBLE=false
HIGH_UPSIDE_MAX_POSITION_NOTIONAL_USD=
HIGH_UPSIDE_MAX_DAILY_LOSS_USDC=
HIGH_UPSIDE_LIVE_CAP_USDC_BY_DURATION_JSON=
HIGH_UPSIDE_LIVE_CAP_PCT_BY_DURATION_JSON=
HIGH_UPSIDE_MAX_SCANNER_REJECTION_RATE=0.65
ML_LIVE_LEARNING_POLICY=quarantine
ML_LIVE_PROMOTION_MIN_EVENTS=25
ML_LIVE_PROMOTION_MAX_MEAN_LOSS=0.20
ML_LIVE_PROMOTION_MAX_NEGATIVE_ERROR_RATE=0.55
ML_OFFLINE_MODELS_ENABLED=false
ML_OFFLINE_BLEND_ENABLED=false
ML_OFFLINE_MODEL_TYPES=sklearn,xgboost
ML_OFFLINE_SCORE_WEIGHT=0.15
ML_OFFLINE_MIN_TRAINING_ROWS=250
ML_OFFLINE_MAX_VALIDATION_LOSS=0.20
ML_OFFLINE_MAX_NEGATIVE_ERROR_RATE=0.55
ML_OFFLINE_MAX_MODEL_AGE_HOURS=72
ML_OFFLINE_MAX_DRIFT=0.35
ML_OFFLINE_MIN_TOP_DECILE_PRECISION=0.55
ML_OFFLINE_MAX_FALSE_POSITIVE_HIGH_UPSIDE_RATE=0.35
ML_OFFLINE_MAX_CALIBRATION_ERROR=0.18
HIGH_UPSIDE_REQUIRE_PROMOTED_ML=true
OPTIMIZER_MARKET_DATA_TIMEOUT_SECONDS=120
OPTIMIZER_PREFILTER_ENABLED=true
OPTIMIZER_SIGNAL_HISTORY_LIMIT=120
MARKET_DATA_CACHE_TTL_SECONDS=5
MARKET_DATA_RESEARCH_CACHE_TTL_SECONDS=60
NET_ROI_MIN_EDGE_BPS=4
NET_ROI_MAX_CHURN_PENALTY=0.35
NET_ROI_MIN_FILL_QUALITY=0.55
NET_ROI_V2_ENABLED=true
NET_ROI_V2_MIN_QUALITY_GRADE=B
ONE_HOUR_EDGE_V2_ENABLED=true
ONE_HOUR_MIN_EDGE_GRADE=B
ONE_HOUR_MAX_RAW_NET_GAP_PCT=35
ONE_HOUR_MIN_EXECUTION_QUALITY=0.60
SIGNAL_DEBOUNCE_SECONDS=45
CANARY_PREVIEW_ONLY=true

# 1-hour convex-edge research profile
AGGRESSIVE_1H_MAX_COST_DRAG_BPS=18
AGGRESSIVE_1H_MIN_CAPACITY_MULTIPLE=2
AGGRESSIVE_1H_MIN_MFE_MAE=1.5
AGGRESSIVE_1H_RECENCY_HALF_LIFE_HOURS=12
AGGRESSIVE_1H_MIN_WINDOW_STABILITY=0.55

# Universe and execution-quality filters
UNIVERSE_MAX_SYMBOLS=20
UNIVERSE_MIN_LIQUIDITY_USD=50000
UNIVERSE_MAX_SPREAD_BPS=12
HOT_TOKEN_SCAN_ENABLED=true
MARKET_STRUCTURE_FEATURES_ENABLED=true
MARKET_STRUCTURE_PROVIDER=existing

# Hard risk controls
MAX_DAILY_LOSS_USDC=5
MAX_POSITION_NOTIONAL=20
MAX_LEVERAGE=3
MAX_SLIPPAGE_PCT=0.015
RISK_PER_TRADE_PCT=0.01

# Live generated wallet addresses
USE_REAL_ADDRESSES=true
WALLET_REAL_CUSTODY_ENABLED=true
WALLET_ALLOW_IN_APP_KEYGEN=true
WALLET_WITHDRAWALS_ENABLED=true
WALLET_REQUIRE_WITHDRAWAL_APPROVAL=true
WALLET_EVM_RPC_URL=
WALLET_EVM_NETWORKS_JSON={"ETHEREUM":{"rpc_url":"","chain_id":1}}
WALLET_EVM_TOKEN_CONTRACTS_JSON={"ETHEREUM":{"USDC":"","USDC_DECIMALS":6,"USDT":"","USDT_DECIMALS":6}}
WALLET_BTC_INDEXER_URL=
WALLET_SOLANA_RPC_URL=
WALLET_XRP_RPC_URL=
WALLET_REQUIRED_CONFIRMATIONS_JSON={"ethereum":12,"bitcoin":2,"solana":32,"xrpledger":1}
WALLET_MAX_WITHDRAWAL_BY_ASSET_JSON={"ETH":0.1,"USDC":100,"USDT":100,"BTC":0.005,"SOL":5,"XRP":500}
