# Flask/runtime
FLASK_SECRET_KEY=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
TOTP_ENCRYPTION_KEY=<required Fernet key>
DATABASE_URL=sqlite:///hyperliquid_dashboard.db

# Runtime posture. Keep paper by default; live orders require explicit opt-in, verified connections, and risk gates.
ENABLE_LIVE_TRADING=false
APP_MODE=paper
EXPLICIT_LIVE_CONFIRMED=false
SECONDARY_CONFIRMATION=false

# Dynamic intraday optimizer
DYNAMIC_UNIVERSE_ENABLED=true
DYNAMIC_INTRADAY_TIMEFRAMES=1m,5m,15m
DYNAMIC_INTRADAY_MIN_EDGE_BPS=6
DYNAMIC_INTRADAY_MIN_LIQUIDITY_USD=50000
DYNAMIC_INTRADAY_MAX_SPREAD_BPS=12
DYNAMIC_INTRADAY_REQUIRE_SHADOW_VALIDATION=true
DYNAMIC_INTRADAY_LIVE_ELIGIBLE=false

# Explicit high-upside profile. Defaults stay capped unless every opt-in gate is set.
