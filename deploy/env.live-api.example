# Algorithm Vault dedicated live API environment template.
# Store these in the fixed-egress live API service env vars. Do not commit real secrets.

APP_ENV=production
DEPLOYMENT_TARGET=vercel
FLASK_APP=wsgi:app

PUBLIC_APP_ORIGIN=https://app.algvault.com
PUBLIC_API_ORIGIN=https://api.algvault.com
PUBLIC_LIVE_API_ORIGIN=https://api.algvault.com
LIVE_API_PROXY_ENABLED=false
LIVE_API_INTERNAL_ORIGIN=https://api.algvault.com
LIVE_API_INTERNAL_TOKEN=CHANGE_ME_SHARED_WITH_VERCEL
LIVE_API_INTERNAL_MAX_SKEW_SECONDS=60
LIVE_API_CORS_ALLOWED_ORIGINS=https://app.algvault.com,https://algorithm-vault-chi.vercel.app
PREFERRED_URL_SCHEME=https
PROXY_FIX_ENABLED=true

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
SCHEMA_BOOTSTRAP_ENABLED=false

WORKER_MODE=web
ENABLE_IN_PROCESS_WORKERS=false
WORKER_PROCESS_CONFIGURED=true

ENABLE_LIVE_TRADING=true
APP_MODE=live
ONE_H10_LIVE_ENABLED=true
VAULT_CYCLE_ENGINE_ENABLED=true
VAULT_CYCLE_REAL_TRANSFERS_ENABLED=true
VAULT_CYCLE_CONVERSION_ENABLED=true
VAULT_START_ASYNC_ENABLED=false

FLASK_SECRET_KEY=CHANGE_ME_32_PLUS_CHARS
TOTP_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
SIGNUP_INVITE_CODE=CHANGE_ME

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
# Set only when the operator console and live API share a parent domain, e.g. app.algvault.com/api.algvault.com.
SESSION_COOKIE_DOMAIN=.algvault.com
SECURE_HEADERS_HSTS_ENABLED=true
LOG_FORMAT=json
LOG_LEVEL=INFO
RATELIMIT_ENABLED=true

# KuCoin is allowed only for an eligible account/operator from a supported region.
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=
KUCOIN_DEFAULT_MARKET_TYPE=futures
KUCOIN_FIXED_EGRESS_REQUIRED=true
KUCOIN_EGRESS_PROXY_URL=
QUOTAGUARDSTATIC_URL=
KUCOIN_COMPLIANCE_CONFIRMED=false
KUCOIN_OPERATOR_REGION=

HL_ACCOUNT_ADDRESS=
HL_SECRET_KEY=

WALLET_WITHDRAWALS_ENABLED=false
WALLET_CUSTODY_MODE=local_dev
WALLET_EMERGENCY_STOP=false
