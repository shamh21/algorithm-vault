# Algorithm Vault production environment template.
# Copy to /etc/algorithm-vault/algorithm-vault.env and fill real values there.
# Do not commit real secrets.

APP_ENV=production
DEPLOYMENT_TARGET=vps
FLASK_APP=wsgi:app

# Public HTTPS posture. Production TLS should terminate at Nginx, a load
# balancer, CDN, Caddy, Traefik, or the hosting platform, not in Gunicorn.
PREFERRED_URL_SCHEME=https
PUBLIC_APP_ORIGIN=https://app.algvault.com
PUBLIC_API_ORIGIN=https://app.algvault.com
PUBLIC_LIVE_API_ORIGIN=
LIVE_API_CORS_ALLOWED_ORIGINS=
PROXY_FIX_ENABLED=true

DATABASE_URL=postgresql+psycopg://algorithm_vault:CHANGE_ME@127.0.0.1:5432/algorithm_vault
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
WORKER_MODE=web
ENABLE_IN_PROCESS_WORKERS=false
WORKER_PROCESS_CONFIGURED=true
WORKER_LEASE_TTL_SECONDS=120
WORKER_POLL_SECONDS=15
# Required when this deployment invokes /api/worker/run for bounded worker ticks.
CRON_SECRET=CHANGE_ME_RANDOM_32_PLUS_CHARS
VERCEL_WORKER_STRATEGY_WINDOW_SECONDS=8
# Keep Gunicorn private; the reverse proxy owns ports 80 and 443.
GUNICORN_BIND=127.0.0.1:8000

FLASK_SECRET_KEY=CHANGE_ME_32_PLUS_CHARS
TOTP_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
SIGNUP_INVITE_CODE=CHANGE_ME

ENABLE_LIVE_TRADING=false
APP_MODE=paper
WTF_CSRF_ENABLED=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_DOMAIN=
SECURE_HEADERS_HSTS_ENABLED=true
LOG_FORMAT=json
LOG_LEVEL=INFO
RATELIMIT_ENABLED=true

# Exchange, wallet, ML, and withdrawal values belong here as needed.
# Keep live trading disabled until `flask production-readiness --strict` is clean.
WALLET_CUSTODY_MODE=encrypted_db
WALLET_WITHDRAWALS_ENABLED=false
WALLET_SIGNER_ISOLATION_REQUIRED=true
WALLET_SIGNER_ISOLATION_CONFIRMED=false
WALLET_SDK_CHECKS_PASSED=false
WALLET_MPC_SIGNER_URL=
WALLET_MPC_SIGNER_TOKEN=
WALLET_SIGNER_TIMEOUT_SECONDS=10
WALLET_EMERGENCY_STOP=false
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_WALLET=0
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_ASSET_JSON={}
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_DESTINATION=0
WALLET_DAILY_GLOBAL_WITHDRAWAL_LIMIT=0
