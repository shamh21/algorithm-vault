APPLE_PAY_EXECUTION_FEE_BUFFER_BPS=500
APPLE_PAY_MIN_FIAT_USD=10
APPLE_PAY_MAX_FIAT_USD=5000
APPLE_PAY_TIMEOUT_SECONDS=12
APPLE_PAY_ONEINCH_SLIPPAGE_PCT=0.5
APPLE_PAY_DOMAIN_ASSOCIATION=
WORKER_APPLE_PAY_FULFILLMENT_ENABLED=true
ONEINCH_API_KEY=
ONEINCH_API_BASE_URL=https://api.1inch.com/swap/v6.1
ONEINCH_REFERRER_ADDRESS=
ONEINCH_PARTNER_FEE_BPS=0
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_WALLET=0
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_ASSET_JSON={}
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_DESTINATION=0
WALLET_DAILY_GLOBAL_WITHDRAWAL_LIMIT=0
