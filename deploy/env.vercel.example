# Algorithm Vault Vercel web/API environment template.
# Store these in Vercel Project Settings > Environment Variables. Do not commit real secrets.

APP_ENV=production
DEPLOYMENT_TARGET=vercel
FLASK_APP=server:app

PUBLIC_APP_ORIGIN=https://YOUR_VERCEL_OR_CUSTOM_DOMAIN
PUBLIC_API_ORIGIN=https://YOUR_VERCEL_OR_CUSTOM_DOMAIN
PUBLIC_LIVE_API_ORIGIN=https://api.algvault.com
LIVE_API_CORS_ALLOWED_ORIGINS=https://YOUR_VERCEL_OR_CUSTOM_DOMAIN,https://algorithm-vault-chi.vercel.app,https://app.algvault.com
PREFERRED_URL_SCHEME=https
PROXY_FIX_ENABLED=true

# Use a Vercel Marketplace Postgres integration such as Neon/Supabase/Aurora.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
SCHEMA_BOOTSTRAP_ENABLED=false

# Vercel serves web/API requests. Continuous live jobs run on Render.
WORKER_MODE=web
ENABLE_IN_PROCESS_WORKERS=false
WORKER_PROCESS_CONFIGURED=true

ENABLE_LIVE_TRADING=true
APP_MODE=live

FLASK_SECRET_KEY=CHANGE_ME_32_PLUS_CHARS
TOTP_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
SIGNUP_INVITE_CODE=CHANGE_ME

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
# Set to .algvault.com only when app.algvault.com and api.algvault.com share auth cookies.
SESSION_COOKIE_DOMAIN=
SECURE_HEADERS_HSTS_ENABLED=true
LOG_FORMAT=json
LOG_LEVEL=INFO
RATELIMIT_ENABLED=true

# Immediate live withdrawals require an isolated MPC signer and positive caps.
WALLET_WITHDRAWALS_ENABLED=true
WALLET_REAL_CUSTODY_ENABLED=true
WALLET_CUSTODY_MODE=mpc
WALLET_REQUIRE_WITHDRAWAL_APPROVAL=false
WALLET_SIGNER_ISOLATION_CONFIRMED=true
WALLET_SDK_CHECKS_PASSED=true
WALLET_MPC_SIGNER_URL=
WALLET_MPC_SIGNER_TOKEN=
WALLET_SIGNER_TIMEOUT_SECONDS=10
WALLET_EMERGENCY_STOP=false
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_WALLET=100
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_ASSET_JSON={"ETH":0.1,"USDC":100,"USDT":100,"BTC":0.005,"SOL":5,"XRP":500}
WALLET_DAILY_WITHDRAWAL_LIMIT_BY_DESTINATION=100
WALLET_DAILY_GLOBAL_WITHDRAWAL_LIMIT=250

# Custom tokenized card/Apple Pay funding. Use real values only in Vercel env.
ONRAMP_PROVIDER_ENABLED=false
ONRAMP_PROVIDER=custom_hosted
ONRAMP_CUSTOM_SESSION_URL=
ONRAMP_CUSTOM_API_KEY=
ONRAMP_CUSTOM_WEBHOOK_SECRET=
ONRAMP_CUSTOM_ALLOWED_ASSETS_JSON={"USDT":["Ethereum"],"USDC":["Ethereum"]}
ONRAMP_CUSTOM_MIN_FIAT_USD=10
ONRAMP_CUSTOM_MAX_FIAT_USD=5000
ONRAMP_CUSTOM_TIMEOUT_SECONDS=12
ONRAMP_CUSTOM_WEBHOOK_TOLERANCE_SECONDS=300
CARD_BUY_ENABLED=false
CARD_GATEWAY_TOKENIZATION_URL=
CARD_GATEWAY_AUTHORIZE_URL=
CARD_GATEWAY_API_KEY=
CARD_GATEWAY_WEBHOOK_SECRET=
CARD_GATEWAY_PUBLIC_CONFIG_JSON={}
APPLE_PAY_DIRECT_ENABLED=false
APPLE_PAY_CRYPTO_SALE_APPROVED=false
APPLE_PAY_MERCHANT_ID=
APPLE_PAY_DISPLAY_NAME=AlgVault
APPLE_PAY_DOMAIN=algvault.app
APPLE_PAY_COUNTRY_CODE=CA
APPLE_PAY_SUPPORTED_NETWORKS=visa,masterCard,amex,discover
APPLE_PAY_MERCHANT_CERT_PATH=
APPLE_PAY_MERCHANT_KEY_PATH=
APPLE_PAY_MERCHANT_CERT_PEM=
APPLE_PAY_MERCHANT_KEY_PEM=
APPLE_PAY_GATEWAY_AUTHORIZE_URL=
APPLE_PAY_GATEWAY_REFUND_URL=
APPLE_PAY_GATEWAY_API_KEY=
APPLE_PAY_GATEWAY_WEBHOOK_SECRET=
APPLE_PAY_GATEWAY_WEBHOOK_TOLERANCE_SECONDS=300
APPLE_PAY_BUY_ALLOWED_ASSETS_JSON={"ETH":{"Ethereum":{"fulfillment_kind":"treasury_transfer","chain_id":1,"decimals":18}},"USDC":{"Ethereum":{"fulfillment_kind":"treasury_transfer","chain_id":1,"token_address":"0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48","decimals":6}},"USDT":{"Ethereum":{"fulfillment_kind":"treasury_transfer","chain_id":1,"token_address":"0xdAC17F958D2ee523a2206206994597C13D831ec7","decimals":6}}}
APPLE_PAY_TREASURY_SOURCE_WALLETS_JSON={}
APPLE_PAY_ASSET_PRICE_USD_JSON={}
APPLE_PAY_TREASURY_SOURCE_ADDRESS=
APPLE_PAY_TREASURY_FEE_ADDRESS=
APPLE_PAY_TREASURY_SIGNER_URL=
APPLE_PAY_TREASURY_SIGNER_TOKEN=
APPLE_PAY_TREASURY_FEE_BPS=250
WALLET_BUY_PLATFORM_FEE_BPS=250
WALLET_BUY_QUOTE_TTL_SECONDS=300
APPLE_PAY_EXECUTION_FEE_BUFFER_BPS=500
APPLE_PAY_MIN_FIAT_USD=10
APPLE_PAY_MAX_FIAT_USD=5000
APPLE_PAY_TIMEOUT_SECONDS=12
APPLE_PAY_ONEINCH_SLIPPAGE_PCT=0.5
APPLE_PAY_DOMAIN_ASSOCIATION=
WORKER_APPLE_PAY_FULFILLMENT_ENABLED=true
ONEINCH_API_KEY=
ONEINCH_API_BASE_URL=https://api.1inch.com/swap/v6.1
ONEINCH_REFERRER_ADDRESS=
ONEINCH_PARTNER_FEE_BPS=0

# Exchange credentials and IP allowlisting must match Vercel Static IPs/Secure Compute.
HL_ACCOUNT_ADDRESS=
HL_SECRET_KEY=
